/**
 * This ruleset provides public read access to global configuration data
 * while restricting all write operations to a predefined set of administrators.
 * The model leverages a separate 'roles_admin' collection for administrative
 * role management, ensuring a clear separation of data and permissions.
 *
 * Core Philosophy:
 * Public read, Admin-only write. This allows anonymous or any authenticated
 * user to view application settings, but only trusted admins can modify them.
 *
 * Data Structure:
 * - /appConfig/{configId}: Contains singleton configuration documents like
 *   `/appConfig/landingPage`.
 * - /roles_admin/{userId}: A collection where the document ID is the UID of an
 *   administrator. The presence of a document indicates admin status. This
 *   collection should be managed via the Firebase Console or a secure backend,

 *   not by client applications.
 *
 * Key Security Decisions:
 * - Public Read Access: The `/appConfig` collection is readable by anyone to
 *   ensure the application can load its configuration for all visitors.
 * - Admin-Only Writes: All write operations (create, update, delete) are
 *   strictly limited to users whose UID is present in the `/roles_admin`
 *   collection.
 * - Client-Side Lockdown of Roles: The `/roles_admin` collection is locked
 *   down completely from any client-side read or write operations to prevent
 *   users from discovering or modifying administrator roles.
 * - Note on 'auth/operation-not-allowed': The user's reported error typically
 *   indicates that the sign-in providers (e.g., Anonymous, Email/Password)
 *   are not enabled in the Firebase Authentication settings in the Firebase
 *   Console. This ruleset assumes authentication is configured correctly.
 *
 * Denormalization for Authorization:
 * This ruleset uses a Database Access Control (DBAC) pattern by storing
 * administrator roles in a dedicated `/roles_admin` collection. A simple and
 * highly performant `exists()` check on this collection is used for
 * authorization, which avoids slow, costly, or impossible security checks
 * that would otherwise require `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user is an administrator.
     * Admin status is determined by the existence of a document corresponding
     * to their UID in the '/roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Verifies that a document exists before an update or delete operation.
     * Prevents operations on non-existent documents.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Validates required relational fields on document creation.
     * Ensures the document's internal `id` matches its path ID.
     */
    function isCreateDataValid(configId) {
      return request.resource.data.id == configId;
    }

    /**
     * Ensures critical relational fields are immutable on update.
     * Prevents the document's internal `id` from being changed.
     */
    function isUpdateDataValid() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * @description
     *   Controls access to the global application configuration documents,
     *   such as the landing page settings.
     * @path /appConfig/{configId}
     * @allow (get) Any user, signed-in or anonymous, can read a config document.
     * @allow (update) An authenticated admin user (UID exists in /roles_admin)
     *   can update an existing document.
     * @deny (create) A regular authenticated user attempts to create a new
     *   configuration document.
     * @principle
     *   Implements a public-read, admin-only write model using a separate
     *   roles collection for authorization (DBAC).
     */
    match /appConfig/{configId} {
      allow get, list: if true;
      allow create: if isAdmin() && isCreateDataValid(configId);
      allow update: if isAdmin() && isExistingDoc() && isUpdateDataValid();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description
     *   Secures the collection that stores administrator user IDs. This
     *   collection is used as the source of truth for role-based access
     *   control throughout the application.
     * @path /roles_admin/{userId}
     * @allow No client-side operations are permitted. This collection must be
     *   managed via the Firebase Console or a trusted server environment.
     * @deny Any user attempting to read or write to this collection from the
     *   client application will be denied.
     * @principle
     *   Protects sensitive authorization data from all client access,
     *   preventing users from discovering who the administrators are or
     *   attempting to elevate their own privileges.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}