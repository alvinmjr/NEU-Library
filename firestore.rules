/**
 * # Core Philosophy
 * This ruleset enforces a hybrid security model designed for a library application.
 * It strictly separates public, read-only catalog data (like books, authors) from private, user-owned data (like loans and reservations).
 * Administrative access is managed through a database-backed access control (DBAC) system, granting elevated privileges to designated library staff.
 *
 * # Data Structure
 * - `/libraryMembers/{userId}`: Contains private user profile data. The document ID must match the user's Firebase Auth UID.
 * - `/libraryMembers/{userId}/{loans|reservations}`: Subcollections containing user-specific records, accessible only to the owner or an admin.
 * - `/books`, `/authors`, `/publishers`, `/genres`: Top-level collections for public catalog data. These are globally readable but not writable by clients.
 * - `/roles_libraryAdmins/{userId}`: A special collection where the existence of a document signifies a user has administrative privileges.
 * - `/visits/{visitId}`: Contains library visit records for statistical analysis. Writable and readable only by admins.
 *
 * # Key Security Decisions
 * - **No User Listing**: To protect user privacy, non-administrative users cannot list or discover other members in the `/libraryMembers` collection.
 * - **Strict Ownership**: All user-specific data (profiles, loans, reservations) is protected by ownership checks, ensuring users can only access their own information.
 * - **Admin Override**: Users with an entry in `/roles_libraryAdmins` have full read/write access to all user data for management purposes.
 * - **Read-Only Catalogs**: Public catalog collections are locked down to prevent modification by clients, assuming this data is managed by a trusted backend server or the Firebase Console.
 *
 * # Denormalization for Authorization
 * To ensure fast and secure authorization, ownership information is denormalized directly onto documents.
 * - `Loan` and `Reservation` documents under a user's subcollection contain a `memberId` field that must match the user's UID.
 * - This avoids slow and costly `get()` calls to parent documents within rules, making the security model more performant and easier to reason about.
 *
 * # Structural Segregation
 * The data model separates public and private data into different top-level collections. This is more secure and performant for list queries than using a single collection with a boolean "isPublic" flag.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if a user is a designated Library Administrator by looking
     * for their UID in the roles collection.
     */
    function isLibraryAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_libraryAdmins/$(request.auth.uid));
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document being accessed already exists.
     * Crucial for robust update and delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Combines owner and admin checks for concise access control.
     */
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isLibraryAdmin();
    }

    /**
     * A robust check for state-changing operations, ensuring the document
     * exists and the user is either the owner or an admin.
     */
    function isExistingOwnerOrAdmin(userId) {
      return isExistingDoc() && isOwnerOrAdmin(userId);
    }

    /**
     * Validates that the `externalAuthId` field in a new libraryMember document
     * correctly matches the user's UID creating it.
     */
    function hasCorrectExternalAuthIdOnCreate(userId) {
      return request.resource.data.externalAuthId == userId;
    }

    /**
     * Ensures the link between a member profile and their auth ID cannot be changed.
     */
    function externalAuthIdIsImmutable() {
      return request.resource.data.externalAuthId == resource.data.externalAuthId;
    }

    /**
     * Validates that the `memberId` field in a new loan/reservation document
     * correctly matches the parent user's UID.
     */
    function hasCorrectMemberIdOnCreate(memberId) {
      return request.resource.data.memberId == memberId;
    }

    /**
     * Ensures the ownership link (`memberId`) on a loan/reservation cannot be changed.
     */
    function memberIdIsImmutable() {
      return request.resource.data.memberId == resource.data.memberId;
    }

    // =====================================================================
    // User-Specific Data
    // =====================================================================

    /**
     * @description Manages library member profiles. A user can create their own profile,
     *   and can only read or modify their own data. Admins have full access.
     * @path /libraryMembers/{libraryMemberId}
     * @allow (create) An authenticated user with UID 'user123' can create their own profile at `/libraryMembers/user123`.
     * @deny (list) An authenticated user 'user123' cannot list all documents in `/libraryMembers`.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /libraryMembers/{libraryMemberId} {
      allow get: if isOwnerOrAdmin(libraryMemberId);
      allow list: if isLibraryAdmin();
      allow create: if isOwner(libraryMemberId) && hasCorrectExternalAuthIdOnCreate(libraryMemberId);
      allow update: if isExistingOwnerOrAdmin(libraryMemberId) && externalAuthIdIsImmutable();
      allow delete: if isExistingOwnerOrAdmin(libraryMemberId);

      /**
       * @description Manages a member's loan records. Only the member or an admin can access these records.
       * @path /libraryMembers/{libraryMemberId}/loans/{loanId}
       * @allow (create) User 'user123' can create a new loan document in their own subcollection.
       * @deny (get) User 'user456' cannot get a loan document from `/libraryMembers/user123/loans/{loanId}`.
       * @principle Enforces data isolation within a user's private subcollections.
       */
      match /loans/{loanId} {
        allow get: if isOwnerOrAdmin(libraryMemberId);
        allow list: if isOwnerOrAdmin(libraryMemberId);
        allow create: if isOwnerOrAdmin(libraryMemberId) && hasCorrectMemberIdOnCreate(libraryMemberId);
        allow update: if isExistingOwnerOrAdmin(libraryMemberId) && memberIdIsImmutable();
        allow delete: if isExistingOwnerOrAdmin(libraryMemberId);
      }

      /**
       * @description Manages a member's reservation records. Only the member or an admin can access these records.
       * @path /libraryMembers/{libraryMemberId}/reservations/{reservationId}
       * @allow (list) User 'user123' can list all reservations in their own subcollection.
       * @deny (update) User 'user456' cannot update a reservation document in user 'user123's subcollection.
       * @principle Enforces data isolation within a user's private subcollections.
       */
      match /reservations/{reservationId} {
        allow get: if isOwnerOrAdmin(libraryMemberId);
        allow list: if isOwnerOrAdmin(libraryMemberId);
        allow create: if isOwnerOrAdmin(libraryMemberId) && hasCorrectMemberIdOnCreate(libraryMemberId);
        allow update: if isExistingOwnerOrAdmin(libraryMemberId) && memberIdIsImmutable();
        allow delete: if isExistingOwnerOrAdmin(libraryMemberId);
      }
    }

    // =====================================================================
    // Public Catalog Data (Read-Only)
    // =====================================================================

    /**
     * @description Public catalog of all books. Anyone can read this data.
     *   Writes are disabled for clients and must be done via a trusted server.
     * @path /books/{bookId}
     * @allow (get, list) Any user, signed in or not, can read the list of books.
     * @deny (create, update, delete) No client user can modify the book catalog.
     * @principle Segregates public data and secures it as read-only for clients.
     */
    match /books/{bookId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Public catalog of all authors. Anyone can read this data.
     * @path /authors/{authorId}
     * @allow (get, list) Any user can read author information.
     * @deny (create, update, delete) No client user can modify the author catalog.
     * @principle Segregates public data and secures it as read-only for clients.
     */
    match /authors/{authorId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Public catalog of all publishers. Anyone can read this data.
     * @path /publishers/{publisherId}
     * @allow (get, list) Any user can read publisher information.
     * @deny (create, update, delete) No client user can modify the publisher catalog.
     * @principle Segregates public data and secures it as read-only for clients.
     */
    match /publishers/{publisherId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Public catalog of all genres. Anyone can read this data.
     * @path /genres/{genreId}
     * @allow (get, list) Any user can read genre information.
     * @deny (create, update, delete) No client user can modify the genre catalog.
     * @principle Segregates public data and secures it as read-only for clients.
     */
    match /genres/{genreId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // =====================================================================
    // Visit Statistics Data
    // =====================================================================
    /**
     * @description Stores library visit records for statistical analysis.
     *   Only library admins can read or write this data.
     * @path /visits/{visitId}
     * @allow (get, list, create, update, delete) An admin can perform any operation on visit records.
     * @deny (get, list, create, update, delete) Regular users cannot access visit records.
     * @principle Secures statistical data for administrative use only.
     */
    match /visits/{visitId} {
      allow read, write: if isLibraryAdmin();
    }


    // =====================================================================
    // Administrative Roles
    // =====================================================================

    /**
     * @description Manages admin roles. The existence of a document here grants a user
     *   admin privileges. This collection is not intended to be managed by clients.
     * @path /roles_libraryAdmins/{adminUid}
     * @allow (get) An authenticated user can check if they themselves are an admin.
     * @deny (list) No user can list all the admins.
     * @deny (create) A regular user cannot make themselves an admin.
     * @principle Implements Database-Backed Access Control (DBAC) for administrative roles, while preventing recursive rule evaluation.
     */
    match /roles_libraryAdmins/{adminUid} {
      allow get: if isOwner(adminUid);
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

  }
}
