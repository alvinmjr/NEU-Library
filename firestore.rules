/**
 * This ruleset enforces a security model for a global application configuration.
 *
 * Core Philosophy: The ruleset is designed to be highly secure yet simple. It manages a public-facing configuration
 * that is readable by anyone (including unauthenticated visitors) but writable only by designated administrators.
 * This addresses the need for a public landing page whose content can be managed dynamically.
 *
 * Data Structure:
 * - /appConfig/{configId}: A collection containing singleton configuration documents. The primary document is /appConfig/landingPage.
 * - /roles_admin/{uid}: A separate, top-level collection that explicitly grants administrator privileges. The existence
 *   of a document with a user's UID as its ID signifies that the user is an admin. This collection is not readable
 *   or writable by any client to prevent discovery of who the administrators are.
 *
 * Key Security Decisions:
 * - Public Read, Admin Write: The /appConfig collection is publicly readable to serve the landing page to all visitors.
 *   All write operations (create, update, delete) are restricted to users identified as administrators.
 * - Decoupled Admin Roles: Administrator status is determined by checking for a document in the /roles_admin collection.
 *   This avoids embedding roles directly into the configuration data, resulting in cleaner and more performant rules.
 *   This is a form of Database Access Control (DBAC).
 * - Client-Side Admin Management is Disallowed: For maximum security, the list of administrators in /roles_admin
 *   cannot be modified or viewed from the client. Admin roles must be managed directly in the Firebase Console
 *   or through a trusted server-side process (e.g., a Cloud Function).
 *
 * Note on `auth/operation-not-allowed` Error: The user-reported error 'auth/operation-not-allowed' is not a
 * Firestore Security Rules issue. It indicates that an authentication method (e.g., Anonymous or Email/Password)
 * is not enabled in the Firebase Console under the "Authentication > Sign-in method" tab. This must be fixed in the
 * project settings for users to be able to sign in.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the user has administrative privileges.
     * Admin status is granted if a document with the user's UID exists in the /roles_admin collection.
     * This is a performant check that does not require reading the document's content.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Rules for the global application configuration.
     *   This data is publicly readable but can only be modified by administrators.
     * @path /appConfig/{configId}
     * @allow (get) Any user, authenticated or not, reading the landing page configuration.
     * @deny (update) A non-administrative signed-in user trying to change the welcome message.
     * @principle Enforces a "Public Read, Admin Write" model using a decoupled roles collection for authorization.
     */
    match /appConfig/{configId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for the admin roles collection.
     *   This collection is used as a lookup table to grant admin privileges. It is locked down completely
     *   from client-side access to prevent users from discovering who the administrators are.
     * @path /roles_admin/{userId}
     * @allow (none) No client-side operations are permitted.
     * @deny (get) Any user attempting to check if another user is an admin.
     * @deny (list) Any user attempting to get a list of all administrators.
     * @principle Secures sensitive authorization data by denying all direct client access. Admin roles
     *   should be managed via the Firebase Console or a trusted backend environment.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}